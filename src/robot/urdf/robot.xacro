<?xml version="1.0"?>
<robot name="robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- 引入xacro文件 -->
  <xacro:include filename="materials.xacro"/>
  <xacro:include filename="lap.xacro"/>
  <xacro:include filename="shin.xacro"/>
  <xacro:include filename="motor.xacro"/>
  <xacro:include filename="wheel.xacro"/>
  <xacro:include filename="radar-front.xacro"/>
  <xacro:include filename="radar-side.xacro"/>
  <xacro:include filename="imu.xacro"/>

  <!-- 新增：动态获取robot包的绝对路径（核心！） -->
  <xacro:property name="pkg_path" value="$(find robot)"/>

  <!-- 基础连杆（作为机器人根节点） -->
  <link name="base_link">
    <!-- 为base_link添加简单可视化（方便在RViz中定位） -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0 0 0"/> <!-- 小方块作为base_link可视化 -->
      </geometry>
      <xacro:get_material_by_name material_name="pla_gray_light"/>
    </visual>
  </link>

  <!-- 身体链接（保留核心可视化、碰撞、惯性，移除gazebo标签） -->
  <link name="body">
    <!-- 视觉属性 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot/meshes/body.obj"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <xacro:get_material_by_name material_name="abs_red"/>
    </visual>
    
    <!-- 碰撞属性（保留，不影响可视化，仅为完整性） -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://robot/meshes/body.obj"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
    
    <!-- 惯性属性（保留，不影响可视化，仅为完整性） -->
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0"
               izz="0.001"/>
    </inertial>
  </link>

  <!-- 底盘与身体的固定关节（保留） -->
  <joint name="base_body_joint" type="fixed">
    <origin xyz="0 0 0" rpy="0 0 ${pi/2}"/>
    <parent link="base_link"/>
    <child link="body"/>
  </joint>
  
  <!-- 大腿部分（保留所有lap宏调用，确保关节可被GUI控制） -->
  <!-- 右前大腿 - 原样 -->
  <xacro:lap suffix="fr" 
             parent_link="body"
             xyz="-0.091 -0.072 0.158"
             rpy="0 0 0"
             mesh_scale="0.001 0.001 0.001"/>
  
  <!-- 左前大腿 - Y轴镜像 -->
  <xacro:lap suffix="fl" 
             parent_link="body"
             xyz="0.091 -0.072 0.158"
             rpy="0 0 0"
             mesh_scale="-0.001 0.001 0.001"/> <!-- Y轴镜像 -->
  
  <!-- 右后大腿 - X轴镜像 -->
  <xacro:lap suffix="rr" 
             parent_link="body"
             xyz="-0.091 0.072 0.158"
             rpy="0 0 0"
             mesh_scale="0.001 -0.001 0.001"/> <!-- X轴镜像 -->
  
  <!-- 左后大腿 - X和Y轴都镜像 -->
  <xacro:lap suffix="rl" 
             parent_link="body"
             xyz="0.091 0.072 0.158"
             rpy="0 0 0"
             mesh_scale="-0.001 -0.001 0.001"/> <!-- X和Y轴镜像 -->


  <!-- 小腿部分 -->
  <!-- 右前小腿 -->
  <xacro:shin suffix="fr" 
              parent_link="lap_fr"
              xyz="-0.017 -0.060 0"
              rpy="0 0 0"
              mesh_scale="0.001 0.001 0.001"/>

  <!-- 左前小腿（Y轴镜像） -->
  <xacro:shin suffix="fl" 
              parent_link="lap_fl"
              xyz="0.017 -0.060 0"
              rpy="0 0 0"
              mesh_scale="-0.001 0.001 0.001"/>

  <!-- 右后小腿（X轴镜像） -->
  <xacro:shin suffix="rr" 
              parent_link="lap_rr"
              xyz="-0.017 0.060 0"
              rpy="0 0 0"
              mesh_scale="0.001 -0.001 0.001"/>

  <!-- 左后小腿（X和Y轴镜像） -->
  <xacro:shin suffix="rl" 
              parent_link="lap_rl"
              xyz="0.017 0.060 0"
              rpy="0 0 0"
              mesh_scale="-0.001 -0.001 0.001"/>

  <!-- 转向部分 -->
  <xacro:motor suffix="fr" 
              parent_link="shin_fr"
              joint_position="front_right"
              xyz="-0.008 0 -0.069"                   
              rpy="0 0 0"
              mesh_scale="0.001 0.001 0.001"/>
  <xacro:motor suffix="fl" 
              parent_link="shin_fl"
              joint_position="front_left"
              xyz="0.008 0 -0.069"                   
              rpy="0 0 0"
              mesh_scale="-0.001 0.001 0.001"/>
  <xacro:motor suffix="rr" 
              parent_link="shin_rr"
              joint_position="rear_right"
              xyz="-0.008 0 -0.069"                   
              rpy="0 0 0"
              mesh_scale="0.001 -0.001 0.001"/>
  <xacro:motor suffix="rl" 
              parent_link="shin_rl"
              joint_position="rear_left"
              xyz="0.008 0 -0.069"                   
              rpy="0 0 0"
              mesh_scale="-0.001 -0.001 0.001"/>


  <!-- 轮胎部分-->
  <xacro:wheel suffix="fr"
             parent_link="motor_fr"
             joint_position="front_right"
             xyz="0.015 0 -0.085"
             rpy="0 0 0"
             mesh_scale="0.001 0.001 0.001"/>
  <xacro:wheel suffix="fl"
             parent_link="motor_fl"
             joint_position="front_left"
             xyz="-0.015 0 -0.085"
             rpy="0 0 0"
             mesh_scale="-0.001 0.001 0.001"/>
  <xacro:wheel suffix="rr"
             parent_link="motor_rr"
             joint_position="rear_right"
             xyz="0.015 0 -0.085"
             rpy="0 0 0"
             mesh_scale="0.001 -0.001 0.001"/>
  <xacro:wheel suffix="rl"
             parent_link="motor_rl"
             joint_position="rear_left"
             xyz="-0.015 0 -0.085"
             rpy="0 0 0"
             mesh_scale="-0.001 -0.001 0.001"/>

  <!-- 前超声波传感器-->
  <xacro:radar-front suffix="fr"
              parent_link="motor_fr"
              xyz="0 -0.037 -0.011"
              rpy="0 0 0"
              mesh_scale="0.001 0.001 0.001"/>
  <xacro:radar-front suffix="fl"
              parent_link="motor_fl"
              xyz="0 -0.037 -0.011"
              rpy="0 0 0"
              mesh_scale="-0.001 0.001 0.001"/>
  <xacro:radar-front suffix="rr"
              parent_link="motor_rr"
              xyz="0 0.037 -0.011"
              rpy="0 0 0"
              mesh_scale="0.001 -0.001 0.001"/>
  <xacro:radar-front suffix="rl"
              parent_link="motor_rl"
              xyz="0 0.037 -0.011"
              rpy="0 0 0"
              mesh_scale="-0.001 -0.001 0.001"/>

  <!-- 侧超声波传感器-->
  <xacro:radar-side suffix="fr"
              parent_link="shin_fr"
              xyz="-0.026 -0.009 -0.035"
              rpy="0 0 0"
              mesh_scale="0.001 0.001 0.001"/>
  <xacro:radar-side suffix="fl"
              parent_link="shin_fl"
              xyz="0.026 -0.009 -0.035"
              rpy="0 0 0"
              mesh_scale="-0.001 0.001 0.001"/>
  <xacro:radar-side suffix="rr"
              parent_link="shin_rr"
              xyz="-0.026 0.009 -0.035"
              rpy="0 0 0"
              mesh_scale="0.001 -0.001 0.001"/>
  <xacro:radar-side suffix="rl"
              parent_link="shin_rl"
              xyz="0.026 0.009 -0.035"
              rpy="0 0 0"
              mesh_scale="-0.001 -0.001 0.001"/>

  <!--  插入 IMU（修改安装位置即可） -->
  <xacro:imu
    parent_link="body"   
    x="0.0"                        
    y="0.0"                        
    z="0.15"                       
    roll="0"
    pitch="0"
    yaw="0"
  />
              
  <xacro:include filename="hardware.xacro"/>

</robot>