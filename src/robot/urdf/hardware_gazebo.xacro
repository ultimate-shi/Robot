<?xml version="1.0"?>
<robot name="robot_hardware" xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!-- 限位参数 -->
  <xacro:property name="lap_limit_deg" value="45"/>
  <xacro:property name="shin_limit_deg" value="45"/>
  <xacro:property name="motor_limit_deg" value="90"/>
  
  <xacro:property name="lap_min_pos" value="${-lap_limit_deg * 3.1415926 / 180}"/>
  <xacro:property name="lap_max_pos" value="${lap_limit_deg * 3.1415926 / 180}"/>
  <xacro:property name="shin_min_pos" value="${-shin_limit_deg * 3.1415926 / 180}"/>
  <xacro:property name="shin_max_pos" value="${shin_limit_deg * 3.1415926 / 180}"/>
  <xacro:property name="motor_min_pos" value="${-motor_limit_deg * 3.1415926 / 180}"/>
  <xacro:property name="motor_max_pos" value="${motor_limit_deg * 3.1415926 / 180}"/>
  
  <xacro:property name="wheel_max_vel" value="5.0"/>

  <ros2_control name="RobotHardwareGazebo" type="system">
    <hardware>
      <plugin>ros_gz_control/GzSystem</plugin>
    </hardware>

    <!-- 右前腿 FR -->
    <joint name="lap_body_joint_fr">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${lap_min_pos}</param>
      <param name="max_position">${lap_max_pos}</param>
    </joint>
    <joint name="shin_lap_fr_joint_fr">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${shin_min_pos}</param>
      <param name="max_position">${shin_max_pos}</param>
    </joint>
    <!-- 匹配 motor.xacro 真实关节名 -->
    <joint name="front_right_steer_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${motor_min_pos}</param>
      <param name="max_position">${motor_max_pos}</param>
    </joint>
    <!-- 匹配 wheel.xacro 真实关节名 -->
    <joint name="front_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="max_velocity">${wheel_max_vel}</param>
    </joint>

    <!-- 左前腿 FL -->
    <joint name="lap_body_joint_fl">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${lap_min_pos}</param>
      <param name="max_position">${lap_max_pos}</param>
    </joint>
    <joint name="shin_lap_fl_joint_fl">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${shin_min_pos}</param>
      <param name="max_position">${shin_max_pos}</param>
    </joint>
    <joint name="front_left_steer_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${motor_min_pos}</param>
      <param name="max_position">${motor_max_pos}</param>
    </joint>
    <joint name="front_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="max_velocity">${wheel_max_vel}</param>
    </joint>

    <!-- 右后腿 RR -->
    <joint name="lap_body_joint_rr">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${lap_min_pos}</param>
      <param name="max_position">${lap_max_pos}</param>
    </joint>
    <joint name="shin_lap_rr_joint_rr">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${shin_min_pos}</param>
      <param name="max_position">${shin_max_pos}</param>
    </joint>
    <joint name="rear_right_steer_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${motor_min_pos}</param>
      <param name="max_position">${motor_max_pos}</param>
    </joint>
    <joint name="rear_right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="max_velocity">${wheel_max_vel}</param>
    </joint>

    <!-- 左后腿 RL -->
    <joint name="lap_body_joint_rl">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${lap_min_pos}</param>
      <param name="max_position">${lap_max_pos}</param>
    </joint>
    <joint name="shin_lap_rl_joint_rl">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${shin_min_pos}</param>
      <param name="max_position">${shin_max_pos}</param>
    </joint>
    <joint name="rear_left_steer_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="min_position">${motor_min_pos}</param>
      <param name="max_position">${motor_max_pos}</param>
    </joint>
    <joint name="rear_left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <param name="max_velocity">${wheel_max_vel}</param>
    </joint>

    <!-- 超声波传感器 -->
    <sensor name="radar_front_fr">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_front_fl">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_front_rr">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_front_rl">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_side_fr">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_side_fl">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_side_rr">
      <state_interface name="distance"/>
    </sensor>
    <sensor name="radar_side_rl">
      <state_interface name="distance"/>
    </sensor>
  </ros2_control>

  <gazebo>
    <plugin name="ros_gz_control" filename="libros_gz_control_system.so">
      <ros><namespace>/robot</namespace></ros>
      <parameters>$(find robot)/config/controller.yaml</parameters>
    </plugin>
  </gazebo>
</robot>